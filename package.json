{
  "name": "orbitaprs",
  "version": "2.0.0",
  "private": true,
  "description": "**APRS satellite and terrestrial communication app** — works in the browser with Web Serial, Web Bluetooth, and WebUSB to connect to KISS TNCs and CH340 devices.",
  "main": "main.js",
  "scripts": {
    "build": "node build.js",
    "build:dev": "node build.js --dev",
    "start": "node build.js --watch",
    "electron": "electron . --no-sandbox",
    "electron:dev": "electron . --dev --no-sandbox",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": ["aprs", "satellite", "kiss", "tnc", "electron", "desktop"],
  "author": "XE2LDL - Luis",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xe2ldl95/OrbitAPRS.git"
  },
  "bugs": {
    "url": "https://github.com/xe2ldl95/OrbitAPRS/issues"
  },
  "homepage": "https://github.com/xe2ldl95/OrbitAPRS#readme",
  "devDependencies": {
    "electron": "^28.2.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {},
  "build": {
    "appId": "com.xe2ldl.OrbitAPRS",
    "productName": "OrbitAPRS",
    "files": [
      "dist/**",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "directories": {
      "buildResources": "build-resources",
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "build-resources/icon.icns"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build-resources/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "category": "Utility",
      "icon": "build-resources/icon.png"
    }
  }
}