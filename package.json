{
  "name": "orbitaprs",
  "version": "0.1.0-rc",
  "private": true,
  "description": "**APRS satellite and terrestrial communication app** — works in the browser with Web Serial, Web Bluetooth, and WebUSB to connect to KISS TNCs and CH340 devices. Native Android via Capacitor.",
  "type": "module",
  "scripts": {
"build": "node build.cjs",
"build:dev": "node build.cjs --dev",
"start": "node build.cjs --watch",
    "cap:init": "cap init",
    "cap:add": "cap add android",
    "cap:sync": "cap sync android",
    "cap:open": "cap open android",
    "cap:build": "cd android && ./gradlew assembleRelease",
    "test": "node tests/test-tcp-kiss.js"
  },
  "keywords": [
    "aprs",
    "satellite",
    "kiss",
    "tnc",
    "capacitor",
    "android",
    "pwa"
  ],
  "author": "XE2LDL - Luis",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xe2ldl95/OrbitAPRS.git"
  },
  "bugs": {
    "url": "https://github.com/xe2ldl95/OrbitAPRS/issues"
  },
  "homepage": "https://github.com/xe2ldl95/OrbitAPRS#readme",
  "dependencies": {
    "@adeunis/capacitor-serial": "^1.0.0",
    "@capacitor-community/bluetooth-le": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@e-is/capacitor-bluetooth-serial": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.0.0",
    "canvas": "^3.2.3",
    "cordova-res": "^0.15.4",
    "typescript": "^7.0.2"
  }
}
